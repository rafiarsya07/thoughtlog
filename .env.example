# Copy this file to ".env" and fill in your own values.

# PostgreSQL connection string.
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/thoughtlog

# Secret used to sign login tokens. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-this-to-a-long-random-string

# The admin account that "npm run seed" creates.
ADMIN_USER=
ADMIN_PASS=

# Name shown on your replies in the comment thread (defaults to "Rafi").
ADMIN_DISPLAY_NAME=Rafi

# Port the server listens on (optional, defaults to 3000).
PORT=

# ----- Email (optional) ------------------------------------------------------
# Leave blank to disable email entirely — subscribe still works, it just won't
# send anything. Fill these in to send a welcome email on subscribe and a
# notification to all subscribers whenever a post is published.
#
# Gmail: turn on 2FA, then create an "App Password" and use it as SMTP_PASS
# (NOT your normal Gmail password). Host smtp.gmail.com, port 465.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ThoughtLog <you@gmail.com>

# Public base URL, used to build links inside emails.
SITE_URL=https://blog.rafiarsya.com
